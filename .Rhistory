habitat_names_en          = c("Zostera (Seagrass)", "Laminaria (Kelp)"),
habitat_names_fr          = c("Zostère (Herbier marin)", "Laminaires (Varech)"),
factor_names_en           = c("Adult feeding", "Predation refuge", "Nursery",
"Connectivity/migration", "Coastal stabilisation"),
